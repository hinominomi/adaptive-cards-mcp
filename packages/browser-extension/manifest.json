{
  "manifest_version": 3,
  "name": "Adaptive Cards AI Builder",
  "version": "1.0.0",
  "description": "AI-powered Adaptive Card generation panel for the Adaptive Cards Designer",
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": [
        "*://adaptivecards.io/*",
        "*://adaptivecards.microsoft.com/*"
      ],
      "js": ["content-script.js"],
      "css": ["ai-panel.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
