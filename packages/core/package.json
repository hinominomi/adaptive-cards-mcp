{
  "name": "adaptive-cards-mcp",
  "version": "2.1.0",
  "description": "AI-powered Adaptive Card generator — MCP server + npm library. 7 tools: generate, validate, optimize, template, transform cards for Teams, Outlook, Copilot.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "adaptive-cards-mcp": "dist/server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./mcp": {
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "tsup && cp -r src/data dist/",
    "dev": "tsup --watch",
    "start": "node dist/server.js",
    "start:mcp": "node dist/server.js",
    "start:sse": "TRANSPORT=sse node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "adaptive-cards",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "microsoft-teams",
    "teams",
    "copilot",
    "card-generator",
    "ai",
    "outlook",
    "bot-framework",
    "claude",
    "cursor",
    "json-schema",
    "accessibility",
    "adaptive-card-template",
    "webex",
    "viva-connections"
  ],
  "author": "Vikrant Singh <msg.vikrant@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VikrantSingh01/adaptive-cards-mcp.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/VikrantSingh01/adaptive-cards-mcp#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.4",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^3.1.4",
    "@types/node": "^22.15.17"
  }
}
